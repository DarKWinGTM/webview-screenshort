{
  "family": "content",
  "name": "tolerant",
  "selector": "content/tolerant",
  "aliases": ["content-tolerant"],
  "description": "Content-tolerant policy for pages with expected copy/data drift but no major structural regression.",
  "fail_on_invalid": true,
  "require_devices": ["desktop", "tablet", "mobile"],
  "max_diff_pixels": 60000,
  "max_diff_ratio": 0.05,
  "fail_on_semantic_structure_change": true,
  "fail_on_semantic_missing": true,
  "fail_on_semantic_content_change": false,
  "fail_on_title_change": false,
  "fail_on_missing_headings": true,
  "fail_on_structure_flags_change": true,
  "fail_on_missing_links": false,
  "fail_on_missing_buttons": false,
  "fail_on_form_count_change": true,
  "fail_on_missing_inputs": true
}
